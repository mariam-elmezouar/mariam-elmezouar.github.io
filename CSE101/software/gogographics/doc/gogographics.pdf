BT 1 0 0 1 0 290 Tm /F4 10 Tf 12 TL (import gogographics) Tj T*  T* (STEPS = 60) Tj T* (PAUSE_LENGTH = 500 / STEPS) Tj T* (START_X, START_Y = 70, 45) Tj T*  T*  T* (def click_to_move\(drawing\):) Tj T* (    ellipse = drawing.new_ellipse\(\)) Tj T* (    ellipse.width\(100\).height\(75\).centre\(\(START_X, START_Y\)\)) Tj T* (    ellipse.fill\(\(230, 100, 140\)\).stroke_width\(3\).stroke\(\(100, 130, 255\)\)) Tj T*  T* (    while True:) Tj T* (        start_x, start_y = ellipse.centre\(\)) Tj T* (        txt = drawing.new_text\(\).string\('Click to move'\).height\(50\)) Tj T*  T* (        end_x, end_y = drawing.get_point\(\)) Tj T* (        txt.visible\(False\)) Tj T* (        dx = \(end_x - start_x\) / STEPS) Tj T* (        dy = \(end_y - start_y\) / STEPS) Tj T*  T* (        for _ in range\(STEPS\):) Tj T* (            ellipse.move\(dx, dy\)) Tj T* (            drawing.pause\(PAUSE_LENGTH\)) Tj T*  T* ET
